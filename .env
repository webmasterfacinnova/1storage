# ──────────────────────────────────────────
# OneStorage – Environment Configuration
# ──────────────────────────────────────────

# --- Google OAuth ---
# Web Client ID from GCloud Console (OAuth 2.0 Web Client)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=310812752601-4mtg7dj18ld7qjc8o8habfb4qer2chp9.apps.googleusercontent.com

# iOS / Android Client IDs (create these in GCloud console when needed)
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# --- MongoDB Backend (optional – for user persistence) ---
# When using a backend API to sync users to MongoDB
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- App Metadata ---
EXPO_PUBLIC_APP_NAME=OneStorage
EXPO_PUBLIC_APP_SCHEME=onestorage
